# dokodemo-claude 環境変数設定
# cp .env.example .env でコピーして使用

# ポート
DC_API_PORT=8001
DC_WEB_PORT=8000

# HTTPS (true: HTTPS起動 / false: HTTP起動)
DC_USE_HTTPS=false

# HTTPS証明書パス (絶対パスで指定。"~" は展開されません)
# mkcert 手動利用例: mkcert -install && mkcert -cert-file /path/server.crt -key-file /path/server.key localhost
DC_HTTPS_CERT_PATH=
DC_HTTPS_KEY_PATH=
# ルートCA (任意、/api/cert で配信)
DC_HTTPS_ROOT_CA_PATH=

# サーバーホスト (0.0.0.0: 全IF / 127.0.0.1: ローカルのみ)
DC_HOST=0.0.0.0

# CORS許可オリジン (カンマ区切り、未設定/"*" で全許可)
# tusアップロードを含む全REST API用。Tailscale IPなど特定オリジンに絞る場合に指定
# 例: DC_CORS_ORIGIN=https://100.100.255.56:8000,https://localhost:8000
DC_CORS_ORIGIN=

# リポジトリ保存先 (相対パス時は backend ディレクトリ基準)
DC_REPOSITORIES_DIR=repositories

# VAPID連絡先 (Safari/Apple Web Push を使う場合)
# DC_VAPID_CONTACT=mailto:your@email.com
